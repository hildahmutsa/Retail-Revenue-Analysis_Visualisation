{
  "datasets": [
    {
      "name": "54c9cec4",
      "displayName": "Customer Transactions Summary by Date and Category",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "SELECT COUNT(`Customer ID`) AS unique_customers, -- I am counting differnt customers in my table\n",
        "       Date,\n",
        "       YEAR(Date) AS trans_year, -- Extract the year from the date column\n",
        "       MONTH(Date) AS trans_month, -- Extraxt the month from the date column\n",
        "       MONTHNAME(Date) AS trans_month_name, -- Extract the month name from the date column\n",
        "       \n",
        "       DAY(Date) AS trans_day, -- Extract the transaction day from the date column\n",
        "       DAYNAME(Date) AS trans_day_name, --Extract the transaction day name from the date column\n",
        "\n",
        "       SUM(`Total Amount`) AS revenue, -- Calculate the total revenue\n",
        "       `Product Category`\n",
        "       \n",
        " from `workspace`.`default`.`retail_sales_data`\n",
        " GROUP BY ALL; -- Grouping my data based on all the non-aggregated columns in my Select Statement"
      ]
    }
  ],
